rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Jobs: any signed-in user can read; only the recruiter can create/update/delete.
    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.recruiterId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.recruiterId == request.auth.uid;
    }

    // User profile + subcollections.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;

      // In-app inbox: owner reads/updates/deletes; any signed-in user may CREATE
      // (e.g. candidate notifies recruiter on apply, recruiter notifies candidate on status).
      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null
          && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.resource.data.keys().hasAll(['type', 'title', 'body', 'read'])
          && request.resource.data.read == false;
      }

      match /bookmarks/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /training_sessions/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /coach_chat/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /collections/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Multiple CVs per candidate (owner writes; recruiters read via application snapshot).
      match /cvs/{cvId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null
          && request.auth.uid == userId;
      }

      // Pre-apply draft per job: selected CV + cover letter (doc id = jobId).
      match /application_drafts/{jobId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }
    }

    // Legacy top-level drafts ({uid}_{jobId}) — read/write for migration.
    match /application_drafts/{draftId} {
      allow read, write: if request.auth != null
        && draftId.matches('^' + request.auth.uid + '_.+');
    }

    // Applications — authenticated access; candidate may withdraw own pending app.
    match /applications/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (
          request.auth.uid
              == get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.recruiterId
          || (
            request.auth.uid == resource.data.candidateId
            && resource.data.status == 'pending'
            && request.resource.data.status == 'withdrawn'
          )
        );
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.candidateId;
    }
    match /conversations/{convId} {
      allow read, write: if request.auth != null;
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }
    match /interviews/{docId} {
      allow read, write: if request.auth != null;
    }
    match /cvs/{docId} {
      allow read, write: if request.auth != null;
    }
    match /cover_letters/{docId} {
      allow read, write: if request.auth != null;
    }
    match /collections/{docId} {
      allow read, write: if request.auth != null;
    }
    match /career_coach_chats/{docId} {
      allow read, write: if request.auth != null;
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
